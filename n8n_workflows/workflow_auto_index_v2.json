      "id": "no-new-files",
      "name": "Brak plikow do indeksowania",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1980, 120]
    },
    {
      "parameters": {
        "jsCode": "// Raport - pliki pominiete (nie wymagaja indeksowania)\nconst checkedFiles = $('Sprawdz status pliku').all();\nconst skipped = checkedFiles.filter(d => !d.json.should_index).length;\nconst toIndex = checkedFiles.filter(d => d.json.should_index).length;\n\nreturn [{\n  json: {\n    message: 'Sprawdzono ' + checkedFiles.length + ' plikow',\n    skippedAlreadyIndexed: skipped,\n    willIndex: toIndex\n  }\n}];"
      },
      "id": "report-skipped",
      "name": "Raport pominiete",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 120]
    }
