{
  "name": "KlimtechRAG — Auto-indeksowanie z Nextcloud (v2 - hash check)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Co 5 minut",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "PROPFIND",
        "url": "http://192.168.31.70:8081/remote.php/webdav/RAG_Dane/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Depth",
              "value": "infinity"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "list-nextcloud",
      "name": "Nextcloud List RAG_Dane",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0],
      "credentials": {
        "httpBasicAuth": {
          "id": "NEXTCLOUD_WEBDAV_CRED_ID",
          "name": "Nextcloud WebDAV"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parsuj odpowiedź WebDAV PROPFIND (XML) i wyciągnij wszystkie pliki\nconst responseText = typeof $input.first().json.data === 'string'\n  ? $input.first().json.data\n  : JSON.stringify($input.first().json);\n\n// Wyciągnij pełne ścieżki plików\nconst filePattern = /RAG_Dane\\/[^<\"\\s]+\\.[a-zA-Z0-9]+/g;\nconst matches = responseText.match(filePattern) || [];\n\n// Deduplikacja\nconst allFiles = [...new Set(matches)];\n\n// Mapowanie ścieżek -> ścieżki lokalne\nconst UPLOAD_BASE = '/media/lobo/BACKUP/KlimtechRAG/data/uploads';\nconst files = allFiles.map(f => {\n  const localPath = UPLOAD_BASE + '/' + f;\n  const ext = f.split('.').pop().toLowerCase();\n  const isPdf = ext === 'pdf';\n  return {\n    remotePath: f,\n    localPath: localPath,\n    extension: ext,\n    isPdf: isPdf\n  };\n});\n\nreturn [{ json: { files: files, totalFiles: files.length } }];"
      },
      "id": "parse-files",
      "name": "Parsuj liste plikow",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "// Przygotuj listę plików do sprawdzenia\nconst data = $input.first().json;\nreturn data.files.map(f => ({ json: f }));"
      },
      "id": "prepare-check",
      "name": "Przygotuj do sprawdzenia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=http://192.168.31.70:8000/files/check?path={{ $json.localPath }}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "check-file-status",
      "name": "Sprawdz status pliku",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "should-index-check",
              "leftValue": "={{ $json.should_index }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-needs-indexing",
      "name": "Czy indeksowac?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1100, 0]
    },
    {
      "parameters": {
        "jsCode": "// Filtruj tylko pliki do indeksowania\nconst data = $input.first().json;\nreturn [{\n  json: {\n    localPath: data.localPath,\n    remotePath: data.remotePath,\n    extension: data.extension,\n    isPdf: data.isPdf,\n    status: data.status\n  }\n}];"
      },
      "id": "filter-to-index",
      "name": "Filtruj do indeksowania",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, -120]
    },
    {
      "parameters": {
        "jsCode": "// Policz ile plików do indeksowania\nconst data = $('Filtruj do indeksowania').all();\nconst count = data.length;\nreturn [{\n  json: {\n    filesToIndex: count,\n    files: data.map(d => d.json)\n  }\n}];"
      },
      "id": "count-files",
      "name": "Policz pliki",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, -120]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-files",
              "leftValue": "={{ $json.filesToIndex }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-has-files",
      "name": "Sa pliki do indeksowania?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1760, -120]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.31.70:8000/model/stop",
        "options": {
          "timeout": 30000
        }
      },
      "id": "stop-llm",
      "name": "Stop LLM (zwolnij VRAM)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1980, -120]
    },
    {
      "parameters": {
        "amount": 10,
        "unit": "seconds"
      },
      "id": "wait-vram",
      "name": "Czekaj 10s (VRAM)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [2200, -120]
    },
    {
      "parameters": {
        "jsCode": "// Przygotuj listę plików do iteracji\nconst data = $('Policz pliki').first().json;\nreturn data.files.map(f => ({ json: f }));"
      },
      "id": "prepare-loop",
      "name": "Przygotuj liste plikow",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, -120]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "pdf-check",
              "leftValue": "={{ $json.isPdf }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "route-filetype",
      "name": "PDF czy tekst?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2640, -120]
    },
