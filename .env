# --- KlimtechRAG Environment Configuration ---

# 1. Konfiguracja modelu (LLM - llama.cpp)
#LLAMA_MODELS_DIR="/home/lobo/.cache/llama.cpp"
#LLAMA_SERVER_ARGS="-ngl -1 -c 8192 --n-predict 2048 -b 2048 -t 32 --repeat_penalty 1.2 --temp 0.2"
#LLAMA_API_PORT="8082"
#BACKEND_API_PORT="8000"

# 2. Klucze API i konfiguracja backend_app (prefix KLIMTECH_)

# Jeśli ustawisz ten klucz, backend będzie wymagał nagłówka X-API-Key o tej wartości.
# Puste lub zakomentowane = brak uwierzytelniania (tryb dev).
#KLIMTECH_API_KEY=""

# Nazwa modelu LLM używanego przez OpenAIGenerator w backend_app/main.py
# Domyślnie: speakleash_Bielik-11B-v3.0-Instruct-Q8_0
#KLIMTECH_LLM_MODEL_NAME="speakleash_Bielik-11B-v3.0-Instruct-Q8_0"

# Maksymalny rozmiar pliku przyjmowanego przez /ingest (w bajtach).
# Domyślnie w kodzie: 50 * 1024 * 1024 (50 MB).
#KLIMTECH_MAX_FILE_SIZE_BYTES="52428800"

# Maksymalna liczba żądań na jedno IP w oknie czasowym.
# Używane przez prosty rate-limiter w backend_app/main.py.
KLIMTECH_RATE_LIMIT_MAX_REQUESTS="60"

# (opcjonalnie) długość okna czasowego rate-limitu w sekundach.
# KLIMTECH_RATE_LIMIT_WINDOW_SECONDS="60"

# Urządzenie dla embedding (cuda:0, cuda:1, cpu)
# Jeśli LLM używa GPU 0, użyj cuda:1 dla embedding
# KLIMTECH_EMBEDDING_DEVICE="cuda:0"
KLIMTECH_EMBEDDING_DEVICE=cuda:0
HIP_VISIBLE_DEVICES=0
