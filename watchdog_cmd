python# W admin.py
@router.get("/chunks/quality")
async def check_chunk_quality():
    """Sprawdza jakość chunków w bazie."""
    import requests as req
    
    resp = req.post(
        f"{settings.qdrant_url}/collections/{settings.qdrant_collection}/points/scroll",
        json={"limit": 100, "with_payload": True},
        timeout=10
    ).json()
    
    points = resp.get("result", {}).get("points", [])
    
    empty = 0
    whitespace_only = 0
    good = 0
    
    for point in points:
        content = point.get("payload", {}).get("content", "")
        real_chars = len(content.replace(" ", "").replace("\n", "").replace("\t", ""))
        if not content:
            empty += 1
        elif real_chars < 20:
            whitespace_only += 1
        else:
            good += 1
    
    return {
        "total_checked": len(points),
        "good": good,
        "whitespace_only": whitespace_only,
        "empty": empty,
        "quality_percent": round(good / len(points) * 100, 1) if points else 0
    }

