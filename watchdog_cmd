Problem: Złej jakości chunki - same białe znaki
To klasyczny problem z ekstrakcją tekstu z PDF. Masz trzy warstwy problemu:
Diagnoza
"oksycgenacja\n\n\n\n\n   ..." → pdftotext wyciąga whitespace zamiast tekstu
Oznacza to że PDF jest skanowanym obrazem (nie ma warstwy tekstowej), ale pdftotext zwrócił coś (nie pusty string) - przez co kod uznał że ekstrakcja się udała i nie uruchomił Docling OCR.
Problem jest w extract_pdf_text() w ingest.py:
python# Ten warunek jest za słaby!
if len(text) > 100:  # ← 100 znaków białych znaków łatwo przekracza 100
    return text

Rozwiązanie
1. Napraw extract_pdf_text() - licz znaki bez whitespace
pythondef extract_pdf_text(file_path: str) -> str:
    import subprocess
    try:
        result = subprocess.run(
            ["pdftotext", "-layout", file_path, "-"],
            capture_output=True, text=True, timeout=30,
        )
        text = result.stdout.strip()
        
        # KLUCZOWA ZMIANA: licz tylko rzeczywiste znaki, nie whitespace
        real_chars = len(text.replace(" ", "").replace("\n", "").replace("\t", ""))
        
        if real_chars > 50:  # minimum 50 prawdziwych znaków
            return text
            
    except Exception:
        pass
    return ""
2. Wyczyść chunki przed indeksowaniem - dodaj filtr w ingest.py
pythondef clean_and_validate_text(text: str) -> str:
    """Usuwa nadmiarowe whitespace i waliduje jakość tekstu."""
    import re
    
    # Usuń nadmiarowe puste linie (max 2 z rzędu)
    text = re.sub(r'\n{3,}', '\n\n', text)
    
    # Usuń linie które są samymi spacjami/tabulatorami
    lines = [line for line in text.splitlines() if line.strip()]
    text = '\n'.join(lines)
    
    return text.strip()


def is_text_quality_ok(text: str, min_real_chars: int = 100) -> bool:
    """Sprawdza czy tekst ma wystarczającą jakość."""
    real_chars = len(text.replace(" ", "").replace("\n", "").replace("\t", ""))
    return real_chars >= min_real_chars
3. Zaktualizuj parse_with_docling() - użyj nowych funkcji
pythondef parse_with_docling(file_path: str) -> str:
    text = extract_pdf_text(file_path)
    
    if text and is_text_quality_ok(text):
        cleaned = clean_and_validate_text(text)
        logger.info("[PDF] pdftotext OK (%d znaków rzeczywistych)", 
                    len(cleaned.replace(" ", "").replace("\n", "")))
        return cleaned

    # Fallback do Docling OCR
    logger.info("[PDF] pdftotext niewystarczający → Docling OCR...")
    from docling.datamodel.pipeline_options import PdfPipelineOptions, RapidOcrOptions
    from docling.document_converter import PdfFormatOption
    from docling.datamodel.base_models import InputFormat
    from docling.document_converter import DocumentConverter

    pipeline_options = PdfPipelineOptions()
    pipeline_options.do_ocr = True
    pipeline_options.ocr_options = RapidOcrOptions(
        lang=["english", "polish"],
        force_full_page_ocr=True,
        bitmap_area_threshold=0.0,
        backend="onnxruntime",
    )
    converter = DocumentConverter(
        format_options={InputFormat.PDF: PdfFormatOption(pipeline_options=pipeline_options)}
    )
    result = converter.convert(file_path)
    text = result.document.export_to_markdown()
    
    return clean_and_validate_text(text)
