# ============================================================
# KlimtechRAG — plik konfiguracyjny (.env)
# Lokalizacja: /media/lobo/BACKUP/KlimtechRAG/.env
# ============================================================

# === Ścieżki bazowe =========================================
KLIMTECH_BASE_PATH=/media/lobo/BACKUP/KlimtechRAG
KLIMTECH_DATA_PATH=/media/lobo/BACKUP/KlimtechRAG/data
KLIMTECH_UPLOAD_BASE=/media/lobo/BACKUP/KlimtechRAG/data/uploads
KLIMTECH_NEXTCLOUD_BASE=/media/lobo/BACKUP/KlimtechRAG/data/nextcloud/data/admin/files/RAG_Dane
KLIMTECH_FILE_REGISTRY_DB=/media/lobo/BACKUP/KlimtechRAG/data/file_registry.db

# === Nextcloud ===============================================
KLIMTECH_NEXTCLOUD_CONTAINER=nextcloud
KLIMTECH_NEXTCLOUD_USER=admin

# === LLM (llama.cpp-server) =================================
KLIMTECH_LLM_BASE_URL=http://localhost:8082/v1
KLIMTECH_LLM_API_KEY=sk-dummy
KLIMTECH_LLM_MODEL_NAME=
# Ścieżka katalogu z modelami GGUF
LLAMA_MODELS_DIR=/media/lobo/BACKUP/KlimtechRAG/modele_LLM
LLAMA_API_PORT=8082

# === Embedding ==============================================
KLIMTECH_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# cpu / cuda:0
# Przy jednej karcie 16GB: zostaw cpu (LLM zajmuje ~14GB)
# Przy dwóch kartach (przyszłość): cuda:1 (druga karta tylko do embeddingu)
KLIMTECH_EMBEDDING_DEVICE=cpu

# === Qdrant ==================================================
KLIMTECH_QDRANT_URL=http://localhost:6333
KLIMTECH_QDRANT_COLLECTION=klimtech_docs

# === Bezpieczeństwo (opcjonalne) ============================
# Zostaw puste dla trybu dev (bez autoryzacji)
KLIMTECH_API_KEY=

# === Open WebUI =============================================
OWUI_PORT=3000
OWUI_DATA_DIR=/media/lobo/BACKUP/KlimtechRAG/data/open-webui
KLIMTECH_OWUI_PORT=3000
KLIMTECH_OWUI_DATA_DIR=/media/lobo/BACKUP/KlimtechRAG/data/open-webui

# === Backend port ===========================================
BACKEND_PORT=8000

# === Logowanie ==============================================
LOG_LEVEL=INFO

# === Watchdog ===============================================
BACKEND_API_PORT=8000
INGEST_TIMEOUT=7200
INGEST_MAX_RETRIES=3
